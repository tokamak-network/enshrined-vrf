+var (
+	chainNameRegex              = regexp.MustCompile(`^[a-zA-Z][a-zA-Z0-9 ]*$`)
+	enshrinedVrfCompressedKeyRe = regexp.MustCompile(`^0x(02|03)[0-9a-fA-F]{64}$`)
+)
+
+type EnshrinedVrfRequest struct {
+	Enabled                          bool   `json:"enabled"`
+	Mode                             string `json:"mode"`
+	TeeEndpoint                      string `json:"teeEndpoint"`
+	PublicKey                        string `json:"publicKey"`
+	EnshrinedVrfTime                 uint64 `json:"enshrinedVrfTime"`
+	L2GenesisEnshrainedVRFTimeOffset string `json:"l2GenesisEnshrainedVRFTimeOffset"`
+	Predeploy                        string `json:"predeploy"`
+	VerifyPrecompile                 string `json:"verifyPrecompile"`
+	SetL1VRFPublicKey                bool   `json:"setL1VrfPublicKey"`
+	AttestationPolicyID              string `json:"attestationPolicyId,omitempty"`
+	VRFEnclaveImageRepository        string `json:"vrfEnclaveImageRepository,omitempty"`
+	VRFEnclaveImageTag               string `json:"vrfEnclaveImageTag,omitempty"`
+}
+
+func (r *EnshrinedVrfRequest) Validate() error {
+	if r == nil || !r.Enabled {
+		return nil
+	}
+	if r.Mode != "tee" {
+		return errors.New("enshrinedVrf.mode must be tee")
+	}
+	if r.TeeEndpoint == "" {
+		return errors.New("enshrinedVrf.teeEndpoint is required")
+	}
+	if !enshrinedVrfCompressedKeyRe.MatchString(r.PublicKey) {
+		return errors.New("enshrinedVrf.publicKey must be a 33-byte compressed SEC1 key")
+	}
+	if !r.SetL1VRFPublicKey {
+		return errors.New("enshrinedVrf.setL1VrfPublicKey must be true")
+	}
+	return nil
+}
+
+func (r *EnshrinedVrfRequest) ToSDKConfig() *trhSdkTypes.EnshrinedVrfConfig {
+	if r == nil || !r.Enabled {
+		return nil
+	}
+	cfg := &trhSdkTypes.EnshrinedVrfConfig{
+		Enabled:                          true,
+		Mode:                             r.Mode,
+		TeeEndpoint:                      r.TeeEndpoint,
+		PublicKey:                        r.PublicKey,
+		EnshrinedVrfTime:                 r.EnshrinedVrfTime,
+		L2GenesisEnshrainedVRFTimeOffset: r.L2GenesisEnshrainedVRFTimeOffset,
+		Predeploy:                        r.Predeploy,
+		VerifyPrecompile:                 r.VerifyPrecompile,
+		SetL1VRFPublicKey:                r.SetL1VRFPublicKey,
+		AttestationPolicyID:              r.AttestationPolicyID,
+		VRFEnclaveImageRepository:        r.VRFEnclaveImageRepository,
+		VRFEnclaveImageTag:               r.VRFEnclaveImageTag,
+	}
+	if cfg.L2GenesisEnshrainedVRFTimeOffset == "" {
+		cfg.L2GenesisEnshrainedVRFTimeOffset = "0x0"
+	}
+	if cfg.Predeploy == "" {
+		cfg.Predeploy = "0x42000000000000000000000000000000000000f0"
+	}
+	if cfg.VerifyPrecompile == "" {
+		cfg.VerifyPrecompile = "0x0000000000000000000000000000000000000101"
+	}
+	return cfg
+}
 
