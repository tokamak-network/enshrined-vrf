 }
 
+func inputEnshrinedVrfFromEnv() *types.EnshrinedVrfConfig {
+	if os.Getenv("TRH_ENABLE_ENSHRAINED_VRF") != "1" {
+		return nil
+	}
+	cfg := &types.EnshrinedVrfConfig{
+		Enabled:                          true,
+		Mode:                             "tee",
+		TeeEndpoint:                      os.Getenv("VRF_TEE_ENDPOINT"),
+		PublicKey:                        os.Getenv("VRF_PUBLIC_KEY"),
+		EnshrinedVrfTime:                 0,
+		L2GenesisEnshrainedVRFTimeOffset: "0x0",
+		Predeploy:                        "0x42000000000000000000000000000000000000f0",
+		VerifyPrecompile:                 "0x0000000000000000000000000000000000000101",
+		SetL1VRFPublicKey:                true,
+		AttestationPolicyID:              os.Getenv("VRF_ATTESTATION_POLICY_ID"),
+		VRFEnclaveImageRepository:        os.Getenv("VRF_ENCLAVE_IMAGE_REPOSITORY"),
+		VRFEnclaveImageTag:               os.Getenv("VRF_ENCLAVE_IMAGE_TAG"),
+	}
+	if et := os.Getenv("VRF_AWS_ENCLAVE_TYPE"); et == "nitro" {
+		cfg.AWS = &types.EnshrinedVrfAWSConfig{
+			EnclaveType:      et,
+			InstanceType:     os.Getenv("VRF_AWS_INSTANCE_TYPE"),
+			EnclaveCpuCount:  atoiOrDefault(os.Getenv("VRF_AWS_ENCLAVE_CPU"), 2),
+			EnclaveMemoryMiB: atoiOrDefault(os.Getenv("VRF_AWS_ENCLAVE_MEMORY_MIB"), 2048),
+			EnclaveCID:       atoiOrDefault(os.Getenv("VRF_AWS_ENCLAVE_CID"), 16),
+			VsockPort:        atoiOrDefault(os.Getenv("VRF_AWS_VSOCK_PORT"), 5000),
+			EifImageURI:      os.Getenv("VRF_AWS_EIF_IMAGE_URI"),
+		}
+	}
+	return cfg
+}
+
+func atoiOrDefault(s string, def int) int {
+	if s == "" {
+		return def
+	}
+	var n int
+	if _, err := fmt.Sscanf(s, "%d", &n); err != nil || n < 0 {
+		return def
+	}
+	return n
+}
