+type EnshrinedVrfConfig struct {
+	Enabled                          bool   `json:"enabled"`
+	Mode                             string `json:"mode"`
+	TeeEndpoint                      string `json:"tee_endpoint"`
+	PublicKey                        string `json:"public_key"`
+	EnshrinedVrfTime                 uint64 `json:"enshrined_vrf_time"`
+	L2GenesisEnshrainedVRFTimeOffset string `json:"l2GenesisEnshrainedVRFTimeOffset"`
+	Predeploy                        string `json:"predeploy"`
+	VerifyPrecompile                 string `json:"verify_precompile"`
+	SetL1VRFPublicKey                bool   `json:"set_l1_vrf_public_key"`
+	AttestationPolicyID              string `json:"attestation_policy_id,omitempty"`
+	VRFEnclaveImageRepository        string `json:"vrf_enclave_image_repository,omitempty"`
+	VRFEnclaveImageTag               string `json:"vrf_enclave_image_tag,omitempty"`
+	AWS                              *EnshrinedVrfAWSConfig `json:"aws,omitempty"`
+}
+
+// EnshrinedVrfAWSConfig captures the AWS-specific deployment knobs for
+// running the VRF enclave inside an EC2 Nitro Enclave. trh-sdk wires
+// these into the Helm overlay (enshrinedVrf.aws.*) so the chart can
+// configure the EIF launcher DaemonSet, vsock-unix bridge sidecar, and
+// EC2 instance selection. EnclaveType="none" disables the AWS path.
+type EnshrinedVrfAWSConfig struct {
+	EnclaveType      string `json:"enclave_type"`
+	InstanceType     string `json:"instance_type,omitempty"`
+	EnclaveCpuCount  int    `json:"enclave_cpu_count,omitempty"`
+	EnclaveMemoryMiB int    `json:"enclave_memory_mib,omitempty"`
+	EnclaveCID       int    `json:"enclave_cid,omitempty"`
+	VsockPort        int    `json:"vsock_port,omitempty"`
+	EifImageURI      string `json:"eif_image_uri,omitempty"`
+}
+
+var (
+	enshrinedVrfPublicKeyRe   = regexp.MustCompile(`^0x(02|03)[0-9a-fA-F]{64}$`)
+	enshrinedVrfNitroInstance = regexp.MustCompile(`^(m5|m5n|m5d|m5dn|m5zn|m6i|m6in|m7i|c5|c5d|c5n|c6i|c6id|c6in|c7i|r5|r5d|r5n|r5dn|r5b|r6i|r6id|r6in|r7i|x2idn|x2iedn|x2iezn|i3en|i4i|z1d|p3dn|p4d|p4de|p5)\.(metal|((4|6|8|12|16|24|32|48)?xlarge|large))$`)
+)
+
+func (c *EnshrinedVrfConfig) Validate() error {
+	if c == nil || !c.Enabled {
+		return nil
+	}
+	if c.Mode != "tee" {
+		return fmt.Errorf("enshrined_vrf.mode must be tee")
+	}
+	if c.TeeEndpoint == "" {
+		return fmt.Errorf("enshrined_vrf.tee_endpoint is required")
+	}
+	if !enshrinedVrfPublicKeyRe.MatchString(c.PublicKey) {
+		return fmt.Errorf("enshrined_vrf.public_key must be a 33-byte compressed SEC1 key")
+	}
+	if c.L2GenesisEnshrainedVRFTimeOffset == "" {
+		c.L2GenesisEnshrainedVRFTimeOffset = "0x0"
+	}
+	if c.Predeploy == "" {
+		c.Predeploy = "0x42000000000000000000000000000000000000f0"
+	}
+	if c.VerifyPrecompile == "" {
+		c.VerifyPrecompile = "0x0000000000000000000000000000000000000101"
+	}
+	if !c.SetL1VRFPublicKey {
+		return fmt.Errorf("enshrined_vrf.set_l1_vrf_public_key must be true")
+	}
+	if c.AWS != nil {
+		switch c.AWS.EnclaveType {
+		case "", "none":
+		case "nitro":
+			if c.AWS.InstanceType == "" {
+				return fmt.Errorf("enshrined_vrf.aws.instance_type is required when aws.enclave_type=nitro")
+			}
+			if !enshrinedVrfNitroInstance.MatchString(c.AWS.InstanceType) {
+				return fmt.Errorf("enshrined_vrf.aws.instance_type %q is not a Nitro Enclaves capable EC2 type", c.AWS.InstanceType)
+			}
+			if c.AWS.EifImageURI == "" {
+				return fmt.Errorf("enshrined_vrf.aws.eif_image_uri is required when aws.enclave_type=nitro")
+			}
+		default:
+			return fmt.Errorf("enshrined_vrf.aws.enclave_type must be nitro or none (got %q)", c.AWS.EnclaveType)
+		}
+	}
+	return nil
+}
