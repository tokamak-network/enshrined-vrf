diff --git a/pkg/stacks/thanos/enshrined_vrf.go b/pkg/stacks/thanos/enshrined_vrf.go
new file mode 100644
index 0000000..50a7f2c
--- /dev/null
+++ b/pkg/stacks/thanos/enshrined_vrf.go
@@ -0,0 +1,59 @@
+package thanos
+
+import (
+	"fmt"
+
+	"github.com/tokamak-network/trh-sdk/pkg/utils"
+)
+
+func (t *ThanosStack) applyEnshrinedVrfValues(valueFile string) error {
+	cfg := t.deployConfig.EnshrinedVrf
+	if cfg == nil || !cfg.Enabled {
+		return nil
+	}
+	if err := cfg.Validate(); err != nil {
+		return err
+	}
+	updates := map[string]interface{}{
+		"enshrinedVrf.enabled":                               true,
+		"enshrinedVrf.mode":                                  cfg.Mode,
+		"enshrinedVrf.teeEndpoint":                           cfg.TeeEndpoint,
+		"enshrinedVrf.publicKey":                             cfg.PublicKey,
+		"enshrinedVrf.predeploy":                             cfg.Predeploy,
+		"enshrinedVrf.verifyPrecompile":                      cfg.VerifyPrecompile,
+		"enshrinedVrf.fork.enshrinedVrfTime":                 cfg.EnshrinedVrfTime,
+		"enshrinedVrf.fork.l2GenesisEnshrainedVRFTimeOffset": cfg.L2GenesisEnshrainedVRFTimeOffset,
+		"opNode.extraArgs": []string{
+			"--sequencer.vrf-mode=tee",
+			fmt.Sprintf("--sequencer.vrf-tee-endpoint=%s", cfg.TeeEndpoint),
+		},
+		"vrfEnclave.enabled": true,
+	}
+	if cfg.VRFEnclaveImageRepository != "" {
+		updates["vrfEnclave.image.repository"] = cfg.VRFEnclaveImageRepository
+	}
+	if cfg.VRFEnclaveImageTag != "" {
+		updates["vrfEnclave.image.tag"] = cfg.VRFEnclaveImageTag
+	}
+	if cfg.AWS != nil && cfg.AWS.EnclaveType == "nitro" {
+		updates["enshrinedVrf.aws.enclaveType"] = cfg.AWS.EnclaveType
+		updates["enshrinedVrf.aws.instanceType"] = cfg.AWS.InstanceType
+		updates["enshrinedVrf.aws.enclaveCpuCount"] = cfg.AWS.EnclaveCpuCount
+		updates["enshrinedVrf.aws.enclaveMemoryMiB"] = cfg.AWS.EnclaveMemoryMiB
+		updates["enshrinedVrf.aws.enclaveCID"] = cfg.AWS.EnclaveCID
+		updates["enshrinedVrf.aws.vsockPort"] = cfg.AWS.VsockPort
+		updates["enshrinedVrf.aws.eifImageURI"] = cfg.AWS.EifImageURI
+		// Disable the plain-Linux container path; the chart's nitro
+		// variant launches the EIF on the host and runs a vsock-unix
+		// bridge sidecar instead.
+		updates["vrfEnclave.enabled"] = false
+		updates["vrfEnclaveLauncher.enabled"] = true
+		updates["vrfEnclaveBridge.enabled"] = true
+	}
+	for path, value := range updates {
+		if err := utils.UpdateYAMLField(valueFile, path, value); err != nil {
+			return fmt.Errorf("update %s: %w", path, err)
+		}
+	}
+	return nil
+}
