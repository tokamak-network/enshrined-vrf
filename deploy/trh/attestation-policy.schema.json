{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tokamak.network/schemas/trh/vrf-attestation-policy.schema.json",
  "title": "TRH VRF attestation policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policyId",
    "mode",
    "status",
    "publicKeyBinding",
    "requiredClaims",
    "releaseRequirements"
  ],
  "properties": {
    "policyId": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": ["sgx", "tdx", "sev-snp"]
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "publicKeyBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "encoding", "lengthBytes"],
      "properties": {
        "field": {
          "const": "public_key"
        },
        "encoding": {
          "const": "compressed-sec1"
        },
        "lengthBytes": {
          "const": 33
        }
      }
    },
    "requiredClaims": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mrSignerOrEquivalent",
        "mrEnclaveOrEquivalent",
        "reportDataIncludesPublicKey",
        "debugDisabled"
      ],
      "properties": {
        "mrSignerOrEquivalent": {
          "type": "string"
        },
        "mrEnclaveOrEquivalent": {
          "type": "string"
        },
        "reportDataIncludesPublicKey": {
          "const": true
        },
        "debugDisabled": {
          "const": true
        }
      }
    },
    "releaseRequirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
