# Copy to devnet/sepolia/.env and fill the live Sepolia values.

# Required: Sepolia execution RPC. The prepare script refuses any chain ID
# other than 11155111, so this cannot accidentally target mainnet.
L1_RPC_URL=https://sepolia.example

# Recommended: Sepolia beacon API. If omitted, op-node starts with
# --l1.beacon.ignore, which is acceptable for local unsafe sequencing but not
# for a fully verifying node.
L1_BEACON_URL=https://sepolia-beacon.example

# Required: funded Sepolia deployer key. This key also becomes the local
# SystemConfig owner in the generated devnet intent.
PRIVATE_KEY=0xYOUR_FUNDED_SEPOLIA_PRIVATE_KEY

# Local L2 chain ID. Keep this away from public OP Stack chain IDs.
L2_CHAIN_ID=901005

# Development-only VRF key used by op-node --sequencer.vrf-mode=local and
# by prepare to register the matching SystemConfig VRF public key.
# Do not reuse this key outside local devnets.
VRF_SK=0xc9afa9d845ba75166b5c215767b1d6934e50c3db36e89b127b8a622b120f6721

# Optional: use a TEE prover instead of local proving. Start vrf-enclave first;
# prepare will read the public key from this endpoint and register it on L1.
# VRF_MODE=tee
# VRF_TEE_ENDPOINT=localhost:50051

# Optional: precomputed 33-byte compressed SEC1 public key. When set, prepare
# registers this key instead of deriving it from VRF_SK or VRF_TEE_ENDPOINT.
# VRF_PUBLIC_KEY=0x02...

# Optional: L2 test key. This is the first Hardhat account and is prefunded
# when fundDevAccounts=true in the generated L2 genesis.
L2_TEST_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Optional: bind local RPC services. Defaults are localhost-only.
# L2_RPC_ADDR=127.0.0.1
# L2_WS_ADDR=127.0.0.1
# L2_AUTHRPC_ADDR=127.0.0.1
# OP_NODE_RPC_ADDR=127.0.0.1
# L2_RPC_HOST=127.0.0.1
# L2_WS_HOST=127.0.0.1
# L2_AUTHRPC_HOST=127.0.0.1
# OP_NODE_RPC_HOST=127.0.0.1
# L2_RPC_PORT=9545
# L2_WS_PORT=9546
# L2_AUTHRPC_PORT=9551
# OP_NODE_RPC_PORT=7545

# Optional build toggles. Leave enabled after changing op-geth/op-node/contracts.
BUILD_BINARIES=1
BUILD_CONTRACTS=1
